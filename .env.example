# ── Required ────────────────────────────────────────────────────────────────

# Substring of Delisa's phone number or email as it appears in iMessage.
# Run `python3 -m homes_tracker list-contacts` to find it.
# Example: CONTACT_ID=+15551234567
CONTACT_ID=

# ID from your Google Sheet URL:
#   https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=

# Your Anthropic API key (https://console.anthropic.com/settings/api-keys)
ANTHROPIC_API_KEY=

# Path to your Google service account credentials JSON.
# See setup.sh for instructions on how to create this.
GOOGLE_CREDENTIALS_FILE=~/.config/homes_tracker/google_credentials.json

# ── Optional ─────────────────────────────────────────────────────────────────

# Display name used in logs (cosmetic only)
# CONTACT_NAME=Delisa Sammy

# Name of the tab in the Google Sheet
# SHEET_TAB=Homes

# How far back to scan on the very first run (days)
# LOOKBACK_DAYS=60

# Polling interval in seconds when running with --watch
# POLL_INTERVAL=300
